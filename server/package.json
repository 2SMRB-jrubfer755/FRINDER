{
    "name": "frinder-backend",
    "version": "1.0.0",
    "description": "Backend for Frinder application",
    "main": "index.ts",
    "scripts": {
        "start": "ts-node --project tsconfig.json index.ts",
        "dev": "nodemon --watch . --ext ts --exec \"ts-node --project tsconfig.json\" index.ts",
        "seed": "ts-node --project tsconfig.json seed.ts",
        "health": "node -e \"require('http').get('http://localhost:5000/health', (res) => { if(res.statusCode !== 200) throw new Error(res.statusCode); });\" 2>/dev/null || exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "mongoose": "^8.2.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.12.7",
        "nodemon": "^3.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    }
}